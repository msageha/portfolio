---
import { getImage } from "astro:assets";
import Base from "../layouts/Base.astro";
import App from "../components/App";
import profileSource from "../images/profile.jpg";

const profile = await getImage({ src: profileSource, width: 800, format: "webp" });
const profileImage = {
  src: profile.src,
  width: Number(profile.attributes.width),
  height: Number(profile.attributes.height),
};

// OG 画像はクローラー互換性のため jpeg で自サイトから配信する
const ogImage = await getImage({ src: profileSource, width: 1200, format: "jpeg" });
const ogImageUrl = new URL(ogImage.src, Astro.site).href;
---

<Base
  title="Portfolio"
  ogTitle="mizuki's Portfolio"
  description="mizuki's Portfolio | 珊瑚 彩主紀のポートフォリオページ"
  canonical="https://msageha.net/"
>
  <Fragment slot="head">
    <meta property="og:image" content={ogImageUrl} />
  </Fragment>
  <App client:load profileImage={profileImage} />
</Base>
